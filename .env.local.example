# ============================================================================
# ART WEBSITE — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================================

# ──── Firebase Client SDK ────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General → Your Apps → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ──── Firebase Admin SDK ─────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Copy project_id, client_email, and private_key from the downloaded JSON file.
# For FIREBASE_ADMIN_PRIVATE_KEY: paste the entire key including -----BEGIN/END-----
# Keep the \n characters as literal text.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ──── Stripe ─────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/test/apikeys
# Publishable key starts with pk_test_
# Secret key starts with sk_test_
# Webhook secret: Install Stripe CLI, run `stripe listen --forward-to localhost:3000/api/webhook`
# Or create a webhook endpoint in Stripe Dashboard → Developers → Webhooks
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ──── Resend (Email) ─────────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys (free tier: 100 emails/day)
RESEND_API_KEY=

# ──── App Configuration ──────────────────────────────────────────────────────
# Base URL — use localhost for dev, your .vercel.app URL for production
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Admin email — receives commission notifications and is the seed admin account
ADMIN_EMAIL=your-admin@email.com

# ──── Seed Script Secret (optional) ─────────────────────────────────────────
# Used to protect the /api/seed endpoint. Set any random string.
SEED_SECRET=change-this-to-a-random-string
