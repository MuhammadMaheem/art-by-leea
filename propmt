  active: boolean;
  expiresAt: Timestamp | string | null;
  createdAt: Timestamp | string;
}
```

**2. Create `src/app/api/admin/promo-codes/route.ts`**
- `GET`: Returns all promo codes from Firestore `promoCodes` collection. Admin auth required.
- `POST`: Creates a new promo code. Validate: code must be non-empty, value must be > 0, percentage type value must be ≤ 100. Auto-uppercase the code. Set `usedCount: 0`. Admin auth required.

**3. Create `src/app/api/admin/promo-codes/[id]/route.ts`**
- `PATCH`: Toggle `active` field. Admin auth required.
- `DELETE`: Hard deletes the promo code document. Admin auth required.

**4. Create `src/app/api/promo/validate/route.ts`** (public, no auth required)
- `POST` accepts `{ code: string, cartTotal: number }`
- Queries `promoCodes` where `code == code.toUpperCase()`
- Validation checks in order:
  1. Document exists → else `{ valid: false, reason: "Invalid promo code" }`
  2. `active === true` → else `{ valid: false, reason: "This promo code is no longer active" }`
  3. `expiresAt` is null OR `expiresAt > now` → else `{ valid: false, reason: "This promo code has expired" }`
  4. `maxUses` is null OR `usedCount < maxUses` → else `{ valid: false, reason: "This promo code has reached its usage limit" }`
