## FEATURE 7 — Firestore-Based Notification System

**Goal**: Key events (new orders, commissions, messages) create notification documents in Firestore. Admin sees a bell icon in the navbar with unread count and a dropdown of recent notifications.

**IMPORTANT**: Use Firestore only. No FCM, no service workers, no push notifications.

### What to build

**1. Update `src/types/index.ts`**
```typescript
interface AppNotification {
  id: string;
  type: "new_order" | "new_commission" | "new_message";
  title: string;
  body: string;
  read: boolean;
  link: string;
  createdAt: Timestamp | string;
}
```

**2. Update Firestore rules** — add:
```
match /notifications/{id} {
  allow read, update: if isAdmin();
  allow create: if true; // API routes use Admin SDK so rules don't matter for writes
  allow delete: if isAdmin();
}
```

**3. Create `src/lib/firebase/notifications.ts`** (server-only helper)

```typescript
export async function createNotification(
  type: "new_order" | "new_commission" | "new_message",
  title: string,
  body: string,
  link: string
) {
  try {
    const db = getAdminDb();
    await db.collection("notifications").add({
      type, title, body, link,
      read: false,
      createdAt: FieldValue.serverTimestamp(),
    });
  } catch (e) {
    console.error("Failed to create notification:", e);
    // Non-blocking — never throw
  }
}
```

**4. Call `createNotification` in existing API routes** (wrap in try/catch, never block the primary operation):

In `POST /api/webhook` after order is written:
```typescript
await createNotification(
  "new_order",
  "New Order Received",
  `Order from ${session.customer_email} — $${(session.amount_total / 100).toFixed(2)}`,
  "/admin/orders"
);
```

In `POST /api/commission` after commission is written:
```typescript
await createNotification(
  "new_commission",
  "New Commission Request",
  `${body.name} requested a ${body.category} commission — Budget: ${body.budget}`,
  "/admin/commissions"
);
```

In `POST /api/messages/send` when sender is a customer:
```typescript
await createNotification(
  "new_message",
  "New Customer Message",
  `${senderName}: "${text.slice(0, 60)}${text.length > 60 ? "..." : ""}"`,
  "/admin/messages"
);
```

**5. Create `src/hooks/useNotifications.ts`**

```typescript
export function useNotifications() {
  const [notifications, setNotifications] = useState<AppNotification[]>([]);
  const [unreadCount, setUnreadCount] = useState(0);

  useEffect(() => {
    // Set up onSnapshot on notifications where read == false, ordered by createdAt desc, limit 20
    const unsubscribe = onSnapshot(
      query(
        collection(db, "notifications"),
        where("read", "==", false),
        orderBy("createdAt", "desc"),
        limit(20)
      ),
      (snapshot) => {
        const notifs = snapshot.docs.map(d => ({ id: d.id, ...d.data() })) as AppNotification[];
        setNotifications(notifs);
        setUnreadCount(notifs.length);
      }
    );
    return () => unsubscribe();
  }, []);

  const markRead = async (id: string) => {
    await updateDoc(doc(db, "notifications", id), { read: true });
  };

  const markAllRead = async () => {
    const batch = writeBatch(db);
    notifications.forEach(n => batch.update(doc(db, "notifications", n.id), { read: true }));
    await batch.commit();
  };

  return { notifications, unreadCount, markRead, markAllRead };
}
```

